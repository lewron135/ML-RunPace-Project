# ============================================================
# RunPace — Environment Variables Template
#
# HOW TO USE:
#   cp .env.example .env.local
#   Edit .env.local with your local values.
#   .env.local is gitignored and will never be committed.
#
# VERCEL DEPLOYMENT:
#   Set these variables in the Vercel dashboard under
#   Project Settings > Environment Variables.
#   The vercel.json rewrite routes /api/* directly to the
#   Python serverless function, so FLASK_API_URL is only
#   needed for local development (where Flask runs separately).
# ============================================================


# ── Frontend (Next.js) ────────────────────────────────────────

# URL of the Flask prediction backend.
# Local development: Flask runs on port 5000 as a separate process.
# Production (Vercel): leave unset — Vercel's vercel.json rewrite
# routes /api/* to api/index.py serverless function directly.
FLASK_API_URL=http://localhost:5000


# ── Backend (Flask / api/index.py) ────────────────────────────

# Absolute path to the directory containing .pkl model files.
# Default (if unset): <project_root>/models
# Override if models are stored outside the project tree.
# RUNPACE_MODEL_DIR=/absolute/path/to/models
